{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["index_html_path", "modules", "assets", "validation", "quality_checks", "keywords", "risks"],
  "properties": {
    "index_html_path": {
      "type": "string",
      "minLength": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "content_sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["figure", "logo", "paper", "stylesheet", "script", "other"]
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lang": {
          "type": "string",
          "description": "BCP-47 language tag rendered into <html lang=\"...\">"
        },
        "canonical": {
          "type": "string",
          "description": "Canonical URL written into <link rel=\"canonical\"> and og:url."
        },
        "og_image": {
          "type": "string",
          "description": "Absolute or root-relative URL to the social card."
        },
        "doi": {"type": "string"},
        "arxiv": {"type": "string"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_check", "html_sanity", "responsive_check"],
      "properties": {
        "link_check": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "html_sanity": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "responsive_check": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "table_reconciliation": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "design_drift": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        }
      }
    },
    "quality_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "links",
              "html_sanity",
              "responsive_layout",
              "asset_independence",
              "visual_consistency",
              "table_reconciliation",
              "design_drift"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "not_run"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
