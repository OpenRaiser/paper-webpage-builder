{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["index_html_path", "modules", "assets", "validation", "risks"],
  "properties": {
    "index_html_path": {
      "type": "string",
      "minLength": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "content_sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["figure", "logo", "paper", "stylesheet", "script", "other"]
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_check", "html_sanity", "responsive_check"],
      "properties": {
        "link_check": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "html_sanity": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        },
        "responsive_check": {
          "type": "string",
          "enum": ["pass", "fail", "not_run"]
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
