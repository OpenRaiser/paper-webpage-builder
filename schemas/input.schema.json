{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["paper_source", "target_output"],
  "properties": {
    "paper_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["latex_project", "pdf_with_assets", "existing_webpage"]
        },
        "has_figures": {
          "type": "boolean"
        },
        "has_tables": {
          "type": "boolean"
        }
      }
    },
    "target_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directory"],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "default": "index.html"
        }
      }
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
